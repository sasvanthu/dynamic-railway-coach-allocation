VITE_API_BASE=http://localhost:4000
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors
VITE_STATION_REFRESH_MS=25000
VITE_PASSENGER_REFRESH_MS=20000
VITE_NEARBY_STATION_LIMIT=5

# Real-time polling intervals for dashboard pages (in milliseconds, min 5000)
VITE_DASHBOARD_REFRESH_MS=15000
VITE_TRAINS_REFRESH_MS=20000
VITE_DISRUPTIONS_REFRESH_MS=10000
VITE_FORECASTS_REFRESH_MS=30000
VITE_RAKE_TRANSFERS_REFRESH_MS=25000

# Optional premium tile provider example:
# VITE_MAP_TILE_URL=https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}.png?key=YOUR_MAPTILER_KEY
# VITE_MAP_TILE_ATTRIBUTION=&copy; MapTiler &copy; OpenStreetMap contributors
